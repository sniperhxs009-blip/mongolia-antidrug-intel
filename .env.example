# ===== 蒙古国禁毒情报系统 环境变量示例（产量优化版）=====
# 基础应用配置（全部保留原始字段）
APP_NAME=蒙古国禁毒全网情报自动采集研判系统
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
TIMEZONE=Asia/Ulaanbaatar
# 数据库持久化配置
DATABASE_URL=sqlite:///./data/intel.db
# 【核心爬虫参数 — 产量优化】
CRAWL_INTERVAL=hourly
CRAWL_MODE=news
# 检索时间窗：蒙古涉毒公开信源稀疏，建议 1y（勿改回 30d 除非只要极新稿）
NEWS_WHEN=1y
FULL_WHEN=1y
FORUM_WHEN=1y
CRAWL_MAX_AGE_DAYS=365
# 单站日限额：国际站按此值；蒙古本土媒体在代码内自动放宽（≥20）
CRAWL_MAX_PER_HOST_PER_DAY=10
# 页面上限：核心浅扫用 CRAWL_MAX_PAGES_CORE；全量用 CRAWL_MAX_PAGES_PER_SOURCE
CRAWL_MAX_PAGES_PER_SOURCE=60
CRAWL_MAX_PAGES_CORE=4
# 递归深度：2=可跟进详情页（0 会导致几乎只采列表页）
CRAWL_MAX_DEPTH=2
# 请求延迟 + 抖动（秒），降低反爬
CRAWL_REQUEST_DELAY_SEC=1.0
CRAWL_DELAY_JITTER_SEC=2.0
# 翻译 / 检索开关
ENABLE_TRANSLATION=true
ENABLE_SEARCH_FEEDS=true
ENABLE_OFFICIAL_CRAWL=true
ENABLE_CORE_OFFICIAL_IN_NEWS=true
ENABLE_OFFICIAL_STATS=true
# 论坛与外媒补充（显著增加条目数，建议 true）
ENABLE_FORUM_SEARCH=true
# 合规硬性约束：永久禁用 VPN/代理；程序不直连蒙古 .gov.mn
CRAWL_FORBID_PROXY=true
CRAWL_PROXY_URL=
CRAWL_PROXY_URLS=
CRAWL_USER_AGENT=Mozilla/5.0 (compatible; MN-AntiDrug-IntelBot/1.0; +https://github.com/mongolia-antidrug-intel)
CRAWL_TIMEOUT_SEC=30
# SMTP 邮箱推送
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code
EMAIL_FROM=your_email@qq.com
EMAIL_TO=your_email@qq.com
EMAIL_DAILY_BRIEF_HOUR=8
EMAIL_DAILY_BRIEF_MINUTE=0
ENABLE_ALERT_EMAIL=true
ALERT_KEYWORDS=专项行动,跨境缉毒,新法,口岸严查,合成毒品,易制毒,UNODC,缉毒大案,吨,公斤,芬太尼,尼秦,安纳咖,大规模走私,边境缴获
