# ===== 蒙古国禁毒情报系统 环境变量示例（定稿降噪/合规版）=====
APP_NAME=蒙古国禁毒全网情报自动采集研判系统
APP_HOST=0.0.0.0
APP_PORT=8000
# 部署时必须改为高强度随机串（禁止使用默认值上线）
SECRET_KEY=change-me-to-a-long-random-string
TIMEZONE=Asia/Ulaanbaatar
DATABASE_URL=sqlite:///./data/intel.db
CRAWL_INTERVAL=hourly
CRAWL_MODE=news
# 修改原因：1y 窗口噪音过大 → 默认 30d
NEWS_WHEN=30d
FULL_WHEN=30d
FORUM_WHEN=30d
CRAWL_MAX_AGE_DAYS=30
CRAWL_MAX_PER_HOST_PER_DAY=10
CRAWL_MAX_PAGES_PER_SOURCE=60
CRAWL_MAX_PAGES_CORE=4
CRAWL_MAX_DEPTH=2
CRAWL_REQUEST_DELAY_SEC=1.0
CRAWL_DELAY_JITTER_SEC=2.0
# 严格过滤（关闭宽松模式）
CRAWL_LOOSE_FILTER=false
ENABLE_TRANSLATION=true
ENABLE_SEARCH_FEEDS=true
ENABLE_OFFICIAL_CRAWL=true
ENABLE_CORE_OFFICIAL_IN_NEWS=true
ENABLE_OFFICIAL_STATS=true
# 修改原因：论坛噪音大，默认关闭，仅手动开启
ENABLE_FORUM_SEARCH=false
CRAWL_FORBID_PROXY=true
CRAWL_PROXY_URL=
CRAWL_PROXY_URLS=
CRAWL_USER_AGENT=Mozilla/5.0 (compatible; MN-AntiDrug-IntelBot/1.0; +https://github.com/mongolia-antidrug-intel)
CRAWL_TIMEOUT_SEC=30
# 鉴权（管理员/研判员）；密码请部署时修改
AUTH_ENABLED=true
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=change-admin-password
AUTH_ANALYST_USER=analyst
AUTH_ANALYST_PASSWORD=change-analyst-password
# 人工部署确认：true 时禁止自动触发外部部署钩子
REQUIRE_MANUAL_DEPLOY=true
# 审计日志保留天数
AUDIT_LOG_RETENTION_DAYS=90
# SMTP（勿提交真实密码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
EMAIL_DAILY_BRIEF_HOUR=8
EMAIL_DAILY_BRIEF_MINUTE=0
ENABLE_ALERT_EMAIL=true
# 分级告警邮箱（可与 EMAIL_TO 相同或分拆）
EMAIL_ALERT_PORT=
EMAIL_ALERT_NPS=
EMAIL_ALERT_JOINT=
EMAIL_ALERT_LAW=
ALERT_KEYWORDS=专项行动,跨境缉毒,新法,口岸严查,合成毒品,易制毒,UNODC,缉毒大案,吨,公斤,芬太尼,尼秦,安纳咖,大规模走私,边境缴获
