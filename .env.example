# ===== 蒙古国禁毒情报系统环境变量 =====

# 应用
APP_NAME=蒙古国禁毒全网情报自动采集研判系统
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
TIMEZONE=Asia/Ulaanbaatar

# 数据库（Render 可用持久盘路径 /var/data）
DATABASE_URL=sqlite:///./data/intel.db

# 爬虫 / 长期新闻监测
CRAWL_INTERVAL=hourly
# 可选: every_30m | hourly | every_6h | every_12h | daily
CRAWL_MODE=news
NEWS_WHEN=7d
CRAWL_REQUEST_DELAY_SEC=1.2
CRAWL_MAX_PAGES_PER_SOURCE=40
ENABLE_SEARCH_FEEDS=true
ENABLE_OFFICIAL_CRAWL=false
ENABLE_TRANSLATION=false
CRAWL_USER_AGENT=Mozilla/5.0 (compatible; MN-AntiDrug-IntelBot/1.0; +https://github.com/mongolia-antidrug-intel)
CRAWL_TIMEOUT_SEC=25
CRAWL_MAX_DEPTH=3

# 邮箱推送（SMTP）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code
EMAIL_FROM=your_email@qq.com
EMAIL_TO=your_email@qq.com
EMAIL_DAILY_BRIEF_HOUR=8
EMAIL_DAILY_BRIEF_MINUTE=0
ENABLE_ALERT_EMAIL=true

# 研判报告
REPORT_LANGUAGE=zh
ALERT_KEYWORDS=专项行动,跨境缉毒,新法,口岸严查,合成毒品,易制毒,UNODC,缉毒大案,管制品
